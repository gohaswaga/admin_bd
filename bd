CREATE TABLE User_Logs(
    id INT IDENTITY (1, 1) PRIMARY KEY,
    username TEXT NOT NULL,
    user_action TEXT NOT NULL,
    action_date DATE NOT NULL,
    action_time TIME NOT NULL,
    action_result TEXT NOT NULL
);

